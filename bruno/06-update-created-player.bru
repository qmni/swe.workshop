meta {
  name: Update created player
  type: http
  seq: 6
}

put {
  url: http://localhost:8080/players/{{playerId}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "updated_{{brunoUsername}}",
    "email": "updated_{{brunoEmail}}",
    "level": 20,
    "experience": 1000,
    "playerClass": "ROGUE",
    "status": "ACTIVE"
  }
}
