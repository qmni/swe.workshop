meta {
  name: Update created player
  type: http
  seq: 8
}

put {
  url: {{baseUrl}}/players/{{playerId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "username": "updated_{{brunoUsername}}",
    "email": "updated_{{brunoEmail}}",
    "level": 20,
    "experience": 1000,
    "playerClass": "ROGUE",
    "status": "ACTIVE"
  }
}
